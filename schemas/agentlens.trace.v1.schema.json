{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentlens.dev/schemas/agentlens.trace.v1.schema.json",
  "title": "AgentLens Trace v1",
  "type": "object",
  "required": ["schemaVersion", "runId", "app", "name", "startedAt", "status", "events"],
  "properties": {
    "schemaVersion": {
      "const": "agentlens.trace.v1"
    },
    "runId": {
      "type": "string",
      "minLength": 1
    },
    "app": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "startedAt": {
      "type": "string",
      "format": "date-time"
    },
    "endedAt": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": ["running", "passed", "failed"]
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "events": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/event"
      }
    }
  },
  "additionalProperties": true,
  "$defs": {
    "event": {
      "type": "object",
      "required": ["id", "ts", "type", "status"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "ts": {
          "type": "string",
          "format": "date-time"
        },
        "type": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "input": true,
        "output": true,
        "durationMs": {
          "type": "number",
          "minimum": 0
        },
        "usage": {
          "type": "object",
          "additionalProperties": true
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    }
  }
}
