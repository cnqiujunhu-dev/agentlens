{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentlens.dev/schemas/agentlens.eval.v1.schema.json",
  "title": "AgentLens Eval v1",
  "type": "object",
  "required": ["version", "name", "assertions"],
  "properties": {
    "version": {
      "const": "agentlens.eval.v1"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "assertions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/assertion"
      }
    }
  },
  "additionalProperties": true,
  "$defs": {
    "assertion": {
      "type": "object",
      "required": ["id", "type"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": [
            "allowed-mcp-servers",
            "forbidden-mcp-tool-risks",
            "forbidden-tool-permissions",
            "forbidden-tools",
            "max-errors",
            "max-tool-duration-ms",
            "max-total-cost-usd",
            "max-workflow-errors",
            "min-workflow-chains",
            "min-workflow-tasks",
            "required-citations",
            "required-event-types",
            "required-final-response",
            "required-tool-metadata"
          ]
        },
        "eventTypes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "allow": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/riskException"
          }
        },
        "exceptions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/riskException"
          }
        },
        "keys": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "max": {
          "type": "number"
        },
        "min": {
          "type": "number"
        },
        "permissions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "requireExceptionExpiry": {
          "type": "boolean"
        },
        "requireExceptionOwner": {
          "type": "boolean"
        },
        "risks": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "servers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "tools": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "riskException": {
      "type": "object",
      "properties": {
        "server": {
          "type": "string"
        },
        "tool": {
          "type": "string"
        },
        "risk": {
          "type": "string"
        },
        "owner": {
          "type": "string"
        },
        "expiresAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": true
    }
  }
}
