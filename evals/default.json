{
  "version": "agentlens.eval.v1",
  "name": "baseline-agent-quality",
  "assertions": [
    {
      "id": "has-core-events",
      "type": "required-event-types",
      "eventTypes": ["llm.prompt", "llm.response", "tool.call", "tool.result"]
    },
    {
      "id": "no-errors",
      "type": "max-errors",
      "max": 0
    },
    {
      "id": "no-workflow-errors",
      "type": "max-workflow-errors",
      "max": 0
    },
    {
      "id": "no-dangerous-tools",
      "type": "forbidden-tools",
      "tools": ["rm", "delete_database", "git.reset.hard", "shell.exec.destructive"]
    },
    {
      "id": "tool-latency-budget",
      "type": "max-tool-duration-ms",
      "max": 3000
    },
    {
      "id": "cost-budget",
      "type": "max-total-cost-usd",
      "max": 0.05
    },
    {
      "id": "has-final-answer",
      "type": "required-final-response"
    },
    {
      "id": "final-answer-has-citation",
      "type": "required-citations",
      "min": 1
    }
  ]
}
